{
  "name": "poc-birify-angular-agent",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start:dev": "ng serve --port=4900 --configuration=development",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:coverage": "ng test --watch=false --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "e2e": "start-server-and-test start:dev http://localhost:4900 cy:run"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@mgreminger/quill-image-resize-module": "^1.2.1",
    "@ngrx/signals": "^21.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@primeuix/themes": "^2.0.0",
    "@tailwindcss/postcss": "^4.1.11",
    "chart.js": "4.4.2",
    "primeclt": "^0.1.5",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.2",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "cypress": "^14.5.4",
    "prettier": "^3.8.1",
    "start-server-and-test": "^2.0.13",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
